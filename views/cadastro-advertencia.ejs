<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title><%= titulo %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body class="bg-light">

  <aside class="sidebar text-bg-dark" id="sidebar">
    <div class="d-flex flex-column p-3 h-100">

      <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0 sidebar-title">Painel</h4>

        <button id="toggleSidebar" class="btn btn-dark border-0">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>

      <%- include('partials/sidebar') %>

      <hr>

      <a href="/logout" class="btn btn-danger mt-auto logout-btn">
        <i class="bi bi-box-arrow-right me-2"></i><span>Sair</span>
      </a>
    </div>
  </aside>

  <main class="main-content p-4">
    <div class="container-fluid">

      <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
          <h1 class="h3 mb-1">Cadastrar Advertência</h1>
          <p class="text-muted mb-0">Preencha os dados abaixo para aplicar uma advertência ao aluno.</p>
        </div>
        <a href="/advertencias" class="btn btn-outline-secondary align-self-lg-start">
          <i class="bi bi-arrow-left me-2"></i>Voltar
        </a>
      </div>

      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
          
          <form action="/advertencias/salvar" method="POST">
            
            <div class="mb-4">
              <label for="alunoId" class="form-label fw-bold">Selecione o Aluno:</label>
              <select class="form-select rounded-3" name="alunoId" id="alunoId" required>
                <option value="" disabled selected>-- Escolha um aluno da lista --</option>
                <% alunos.forEach(aluno => { %>
                  <option value="<%= aluno.id %>">
                    <%= aluno.nome %> (Matrícula: <%= aluno.matricula %>) <%= aluno.turma ? ' - ' + aluno.turma : '' %>
                  </option>
                <% }) %>
              </select>
              <div class="form-text">Apenas alunos ativos no sistema são listados.</div>
            </div>

            <div class="mb-4">
              <label for="motivo" class="form-label fw-bold">Motivo / Descrição da Ocorrência:</label>
              <textarea class="form-control rounded-3" name="motivo" id="motivo" rows="5" required placeholder="Descreva detalhadamente o motivo da advertência..."></textarea>
            </div>

            <div class="d-flex gap-2 justify-content-end border-top pt-3">
              <a href="/advertencias" class="btn btn-light px-4">Cancelar</a>
              <button type="submit" class="btn btn-success px-4">
                <i class="bi bi-check-circle me-2"></i>Salvar Registro
              </button>
            </div>

          </form>

        </div>
      </div>

    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/dashboard.js"></script>
</body>
</html>
