<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title><%= titulo %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body class="bg-light">

  <aside class="sidebar text-bg-dark" id="sidebar">
    <div class="d-flex flex-column p-3 h-100">

      <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0 sidebar-title">Painel</h4>

        <button id="toggleSidebar" class="btn btn-dark border-0">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>

      <ul class="nav nav-pills flex-column gap-2">
        <li>
          <a href="/dashboard" class="nav-link active">
            <i class="bi bi-speedometer2 me-2"></i><span>Dashboard</span>
          </a>
        </li>

        <li>
          <a href="/alunos" class="nav-link text-white">
            <i class="bi bi-people me-2"></i><span>Registros de Alunos</span>
          </a>
        </li>

        <li>
          <a href="/presencas" class="nav-link text-white">
            <i class="bi bi-check2-square me-2"></i><span>Presenças</span>
          </a>
        </li>

        <li>
          <a class="nav-link text-white opacity-50 disabled" aria-disabled="true">
            <i class="bi bi-exclamation-triangle me-2"></i><span>Ocorrências</span>
          </a>
        </li>

        <li>
          <a class="nav-link text-white opacity-50 disabled" aria-disabled="true">
            <i class="bi bi-star me-2"></i><span>Pontuação</span>
          </a>
        </li>

        <li>
          <a href="/leitor-qrcode" target="_blank" class="nav-link text-white">
            <i class="bi bi-qr-code-scan me-2"></i><span>Leitor QR Code</span>
          </a>
        </li>
      </ul>

      <hr>

      <a href="/logout" class="btn btn-outline-light mt-auto logout-btn">
        <i class="bi bi-box-arrow-right me-2"></i><span>Sair</span>
      </a>
    </div>
  </aside>

  <main class="main-content p-4">
    <div class="container-fluid">

      <div class="mb-4">
        <h1 class="h3 mb-1">Dashboard</h1>
        <p class="text-muted mb-0">
          Bem-vindo, <%= usuario.nome || usuario.login %>
        </p>
      </div>

      <div class="row g-4 mb-4">
        <div class="col-12 col-md-6 col-xl-3">
          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <p class="text-muted mb-1">Total de Alunos</p>
                  <h3 class="mb-0"><%= totalAlunos %></h3>
                </div>
                <i class="bi bi-people fs-1 text-primary"></i>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <p class="text-muted mb-1">Presenças</p>
                  <h3 class="mb-0" id="totalPresencas"><%= totalPresencas %></h3>
                </div>
                <i class="bi bi-check-circle fs-1 text-success"></i>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <p class="text-muted mb-1">Ocorrências</p>
                  <h3 class="mb-0">0</h3>
                </div>
                <i class="bi bi-exclamation-triangle fs-1 text-warning"></i>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <p class="text-muted mb-1">Pontuação</p>
                  <h3 class="mb-0">0</h3>
                </div>
                <i class="bi bi-star fs-1 text-danger"></i>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 py-3">
          <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Últimas entradas por QR Code</h5>
            <span class="badge text-bg-primary">Registros</span>
          </div>
        </div>

        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead class="table-light">
                <tr>
                  <th>Aluno</th>
                  <th>Turma</th>
                  <th>Status</th>
                  <th>Data e Hora</th>
                </tr>
              </thead>

              <tbody id="tabelaPresencas" data-presencas-view="resumo">
                <% if (registros.length === 0) { %>
                  <tr>
                    <td colspan="4" class="text-center text-muted py-4">
                      Nenhuma entrada registrada ainda.
                    </td>
                  </tr>
                <% } %>

                <% registros.forEach(registro => { %>
                  <tr>
                    <td><%= registro.nome %></td>
                    <td><%= registro.turma || '-' %></td>
                    <td>
                      <span class="badge text-bg-success">
                        <%= registro.status || 'presente' %>
                      </span>
                    </td>
                    <td><%= registro.dataHora %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/dashboard.js"></script>
</body>
</html>
