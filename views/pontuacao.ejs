<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title><%= titulo %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body class="bg-light">

  <aside class="sidebar text-bg-dark" id="sidebar">
    <div class="d-flex flex-column p-3 h-100">

      <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0 sidebar-title">Painel</h4>

        <button id="toggleSidebar" class="btn btn-dark border-0">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>

      <%- include('partials/sidebar') %>

      <hr>

      <a href="/logout" class="btn btn-danger mt-auto logout-btn">
        <i class="bi bi-box-arrow-right me-2"></i><span>Sair</span>
      </a>
    </div>
  </aside>

  <main class="main-content p-4">
    <div class="container-fluid">

      <div class="mb-4">
        <h1 class="h3 mb-1">Controle de Pontuação</h1>
        <p class="text-muted mb-0">Gerenciamento de pontos dos alunos</p>
      </div>

      <div class="row g-4 mb-4">
        <div class="col-12 col-md-6 col-xl-3">
          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
              <p class="text-muted mb-1">Alunos Ativos</p>
              <h3 class="mb-0"><%= alunos.length %></h3>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
              <p class="text-muted mb-1">Maior Pontuação</p>
              <h3 class="mb-0">150</h3>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
              <p class="text-muted mb-1">Pontos Adicionados</p>
              <h3 class="mb-0">320</h3>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
              <p class="text-muted mb-1">Pontos Retirados</p>
              <h3 class="mb-0">95</h3>
            </div>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-white border-0 py-3">
          <h5 class="mb-0">Alteração de Pontuação</h5>
        </div>

        <div class="card-body">
          <form action="/pontuacoes/salvar" method="POST" id="formPontuacao">
            <div class="row g-3">
              
              <div class="col-md-6">
                <label class="form-label" for="alunoBusca">Aluno</label>
                <input list="listaAlunos" id="alunoBusca" class="form-control" placeholder="Digite para pesquisar o aluno..." required>
                <input type="hidden" name="alunoId" id="alunoId">
                
                <datalist id="listaAlunos">
                  <% if (typeof alunos !== 'undefined' && alunos.length > 0) { %>
                    <% alunos.forEach(aluno => { %>
                      <option data-id="<%= aluno.id %>" value="<%= aluno.nome %> (<%= aluno.turma || 'Sem Turma' %>)"></option>
                    <% }) %>
                  <% } %>
                </datalist>
              </div>

              <div class="col-md-3">
                <label class="form-label" for="tipo">Tipo</label>
                <select name="tipo" id="tipo" class="form-select" required>
                  <option value="adicionar">Adicionar</option>
                  <option value="remover">Remover</option>
                </select>
              </div>

              <div class="col-md-3">
                <label class="form-label" for="pontos">Pontos</label>
                <input type="number" name="pontos" id="pontos" class="form-control" min="1" required placeholder="Ex: 10">
              </div>

              <div class="col-12">
                <label class="form-label" for="motivo">Observação / Motivo</label>
                <textarea name="motivo" id="motivo" class="form-control" rows="3" placeholder="Informe o motivo da alteração..." required></textarea>
              </div>
            </div>

            <div class="mt-4">
              <button type="submit" class="btn btn-primary px-4">Salvar Alteração</button>
            </div>
          </form>
        </div>
      </div>

      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 py-3">
          <h5 class="mb-0">Histórico de Alterações</h5>
        </div>

        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead class="table-light">
                <tr>
                  <th>Data</th>
                  <th>Aluno</th>
                  <th>Turma</th>
                  <th>Tipo</th>
                  <th>Pontos</th>
                  <th>Observação</th>
                  <th>Responsável</th>
                </tr>
              </thead>

              <tbody>
                <% if (typeof pontuacoes !== 'undefined' && pontuacoes.length > 0) { %>
                  <% pontuacoes.forEach(p => { %>
                    <tr>
                      <td><%= p.dataHora %></td>
                      <td><strong><%= p.nomeAluno %></strong></td>
                      <td><%= p.turma || '---' %></td>
                      <td>
                        <% if (p.tipo === 'adicionar') { %>
                          <span class="badge text-bg-success">+ Adicionados</span>
                        <% } else { %>
                          <span class="badge text-bg-danger">- Retirados</span>
                        <% } %>
                      </td>
                      <td>
                        <strong class="<%= p.tipo === 'adicionar' ? 'text-success' : 'text-danger' %>">
                          <%= p.tipo === 'adicionar' ? '+' : '-' %><%= p.pontos %>
                        </strong>
                      </td>
                      <td><%= p.motivo %></td>
                      <td><i class="bi bi-person me-1"></i><%= p.responsavel %></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="7" class="text-center text-muted py-4">Nenhuma alteração de pontuação registrada no momento.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/dashboard.js"></script>

  <script>
    document.getElementById('alunoBusca').addEventListener('input', function(e) {
      const input = e.target;
      const list = document.getElementById('listaAlunos');
      const options = list.options;
      const hiddenInput = document.getElementById('alunoId');
      
      hiddenInput.value = ""; 
      for (let i = 0; i < options.length; i++) {
        if (options[i].value === input.value) {
          hiddenInput.value = options[i].getAttribute('data-id');
          break;
        }
      }
    });

    // Bloqueia o envio se o usuário digitar um nome que não está cadastrado
    document.getElementById('formPontuacao').addEventListener('submit', function(e) {
      const hiddenInput = document.getElementById('alunoId');
      if (!hiddenInput.value) {
        e.preventDefault();
        alert('Por favor, selecione um aluno válido da lista sugerida.');
      }
    });
  </script>
</body>
</html>
