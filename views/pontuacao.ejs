<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title><%= titulo %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body class="bg-light">

  <aside class="sidebar text-bg-dark" id="sidebar">
    <div class="d-flex flex-column p-3 h-100">

      <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0 sidebar-title">Painel</h4>

        <button id="toggleSidebar" class="btn btn-dark border-0">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>

      <%- include('partials/sidebar') %>

      <hr>

      <a href="/logout" class="btn btn-outline-light mt-auto logout-btn">
        <i class="bi bi-box-arrow-right me-2"></i><span>Sair</span>
      </a>
    </div>
  </aside>

  <main class="main-content p-4">
    <div class="container-fluid">

      <div class="mb-4">
        <h1 class="h3 mb-1">Controle de Pontuação</h1>
        <p class="text-muted mb-0">Gerenciamento de pontos dos alunos</p>
      </div>

      <div class="row g-4 mb-4">
        <div class="col-12 col-md-6 col-xl-3">
          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
              <p class="text-muted mb-1">Alunos</p>
              <h3 class="mb-0">28</h3>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
              <p class="text-muted mb-1">Maior Pontuação</p>
              <h3 class="mb-0">150</h3>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
              <p class="text-muted mb-1">Pontos Adicionados</p>
              <h3 class="mb-0">320</h3>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
              <p class="text-muted mb-1">Pontos Retirados</p>
              <h3 class="mb-0">95</h3>
            </div>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-white border-0 py-3">
          <h5 class="mb-0">Alteração de Pontuação</h5>
        </div>

        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Aluno</label>
              <select class="form-select">
                <option>Selecione um aluno</option>
              </select>
            </div>

            <div class="col-md-3">
              <label class="form-label">Tipo</label>
              <select class="form-select">
                <option>Adicionar</option>
                <option>Remover</option>
              </select>
            </div>

            <div class="col-md-3">
              <label class="form-label">Pontos</label>
              <input type="number" class="form-control">
            </div>

            <div class="col-12">
              <label class="form-label">Observação</label>
              <textarea class="form-control" rows="3" placeholder="Informe o motivo da alteração..."></textarea>
            </div>
          </div>

          <div class="mt-4 d-flex gap-2">
            <button class="btn btn-success">Adicionar Pontos</button>
            <button class="btn btn-danger">Remover Pontos</button>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 py-3">
          <h5 class="mb-0">Histórico de Alterações</h5>
        </div>

        <div class="card-body">
          <table class="table table-hover align-middle">
            <thead class="table-light">
              <tr>
                <th>Data</th>
                <th>Aluno</th>
                <th>Tipo</th>
                <th>Pontos</th>
                <th>Total Atual</th>
                <th>Observação</th>
                <th>Professor</th>
              </tr>
            </thead>

            <tbody>
              <tr>
                <td>10/06/2026 14:30</td>
                <td>João Pedro</td>
                <td><span class="badge text-bg-success">+ Pontos</span></td>
                <td>+10</td>
                <td><strong>120</strong></td>
                <td>Participou da atividade Maker.</td>
                <td>Professor Diego</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/dashboard.js"></script>
</body>
</html>