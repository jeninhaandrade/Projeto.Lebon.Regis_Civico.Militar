<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title><%= titulo %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body class="bg-light">
  <aside class="sidebar text-bg-dark" id="sidebar">
    <div class="d-flex flex-column p-3 h-100">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0 sidebar-title">Painel</h4>

        <button id="toggleSidebar" class="btn btn-dark border-0">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>

      <%- include('partials/sidebar') %>

      <hr>

      <a href="/logout" class="btn btn-outline-light mt-auto logout-btn">
        <i class="bi bi-box-arrow-right me-2"></i><span>Sair</span>
      </a>
    </div>
  </aside>

  <main class="main-content p-4">
    <div class="container-fluid">
      <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-4">
        <div>
          <h1 class="h3 mb-1">Presenças</h1>
          <p class="text-muted mb-0">
            Registros preenchidos automaticamente pela leitura do QR Code da carteirinha.
          </p>
        </div>

        <a href="/leitor-qrcode" target="_blank" class="btn btn-primary align-self-lg-start">
          <i class="bi bi-qr-code-scan me-2"></i>Abrir leitor
        </a>
      </div>

      <div class="row g-4 mb-4">
        <div class="col-12 col-md-6 col-xl-3">
          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <p class="text-muted mb-1">Total de Presenças</p>
                  <h3 class="mb-0" id="totalPresencas"><%= totalPresencas %></h3>
                </div>
                <i class="bi bi-check-circle fs-1 text-success"></i>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <p class="text-muted mb-1">Hoje</p>
                  <h3 class="mb-0" id="presencasHoje"><%= totalPresentesHoje %></h3>
                </div>
                <i class="bi bi-calendar-check fs-1 text-primary"></i>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <div class="card border-0 shadow-sm rounded-4 card-filtro" id="cardFaltantes" style="cursor:pointer;">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <p class="text-muted mb-1">Faltaram Hoje</p>
                  <h3 class="mb-1"><%= totalFaltantesHoje %></h3>

                  <small class="text-primary fw-semibold" id="textoCardFaltantes">
                    <i class="bi bi-hand-index-thumb me-1"></i>
                    Clique para ver os nomes
                  </small>
                </div>

                <i class="bi bi-person-x fs-1 text-danger"></i>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12 col-xl-6">
          <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center gap-3">
              <div class="icone-sucesso flex-shrink-0">
                <i class="bi bi-person-check"></i>
              </div>

              <div class="min-w-0">
                <p class="text-muted mb-1">Última presença confirmada</p>
                <h5 class="mb-1 text-truncate" id="ultimaPresenca">Nenhuma leitura ainda</h5>
                <p class="text-muted mb-0 small" id="ultimaPresencaHorario">Aguardando QR Code</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 py-3">
          <div class="d-flex flex-column flex-xl-row justify-content-between gap-3">
            <div>
              <h5 class="mb-1">Registros de presença</h5>
              <span class="text-muted small" id="statusAtualizacao">Sincronizando com o leitor...</span>
            </div>

            <div class="presencas-filtros">
              <div class="input-group busca-group">
                <span class="input-group-text bg-white">
                  <i class="bi bi-search"></i>
                </span>
                <input
                  type="search"
                  class="form-control border-0 shadow-none"
                  id="buscaPresenca"
                  placeholder="Buscar por aluno, matrícula ou CPF"
                  autocomplete="off"
                >
              </div>

              <input type="date" class="form-control filtro-select" id="filtroDataPresenca">

              <button type="button" class="btn btn-outline-secondary btn-buscar" id="limparFiltrosPresenca">
                <i class="bi bi-x-lg me-1"></i>Limpar
              </button>
            </div>
          </div>
        </div>

        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead class="table-light">
                <tr>
                  <th>Aluno</th>
                  <th>Matrícula</th>
                  <th>CPF</th>
                  <th>Turma</th>
                  <th>Status</th>
                  <th>Data e Hora</th>
                </tr>
              </thead>

              <tbody id="tabelaPresencas" data-presencas-view="completo">
                <% if (registros.length === 0) { %>
                  <tr>
                    <td colspan="6" class="text-center text-muted py-4">
                      Nenhuma presença registrada ainda.
                    </td>
                  </tr>
                <% } %>

                <% registros.forEach(registro => { %>
                  <tr>
                    <td><%= registro.nome %></td>
                    <td><%= registro.matricula || '-' %></td>
                    <td><%= registro.cpf || '-' %></td>
                    <td><%= registro.turma || '-' %></td>
                    <td>
                      <span class="badge text-bg-success">
                        <%= registro.status || 'presente' %>
                      </span>
                    </td>
                    <td><%= registro.dataHora %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div id="areaFaltantes" style="display:none;">
        <h5 class="mt-4 mb-3">Alunos que faltaram hoje</h5>

        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead class="table-light">
              <tr>
                <th>Aluno</th>
                <th>Matrícula</th>
                <th>CPF</th>
                <th>Turma</th>
                <th>Status</th>
              </tr>
            </thead>

            <tbody>
              <% if (faltantesHoje.length === 0) { %>
                <tr>
                  <td colspan="5" class="text-center text-muted py-4">
                    Nenhum aluno faltou hoje.
                  </td>
                </tr>
              <% } %>

              <% faltantesHoje.forEach(aluno => { %>
                <tr>
                  <td><%= aluno.nome %></td>
                  <td><%= aluno.matricula || '-' %></td>
                  <td><%= aluno.cpf || '-' %></td>
                  <td><%= aluno.turma || '-' %></td>
                  <td>
                    <span class="badge text-bg-danger">Faltou</span>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/dashboard.js"></script>
  <script>
    const cardFaltantes = document.getElementById('cardFaltantes');
    const areaFaltantes = document.getElementById('areaFaltantes');
    const textoCardFaltantes = document.getElementById('textoCardFaltantes');

    cardFaltantes.addEventListener('click', () => {
      const aberto = areaFaltantes.style.display === 'block';

      areaFaltantes.style.display = aberto ? 'none' : 'block';
      textoCardFaltantes.innerHTML = aberto
        ? '<i class="bi bi-hand-index-thumb me-1"></i>Clique para ver os nomes'
        : '<i class="bi bi-eye-slash me-1"></i>Clique para ocultar';
    });
  </script>
</body>
</html>
