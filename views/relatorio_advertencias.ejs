<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title><%= titulo %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">

  <style>
    .relatorio-documento {
      background: #fff;
      border: 1px solid #e5e7eb;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
    }

    .relatorio-cabecalho {
      border-bottom: 2px solid #212529;
      padding-bottom: 18px;
    }

    .relatorio-marca {
      width: 54px;
      height: 54px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 8px;
      overflow: hidden;
      background: #fff;
    }

    .relatorio-marca img {
      width: 42px;
      height: 42px;
      object-fit: contain;
      opacity: 0.70;
    }

    .relatorio-meta {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
    }

    .relatorio-meta-item {
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      padding: 10px 12px;
      background: #f8f9fa;
    }

    .relatorio-meta-item span {
      display: block;
      color: #6c757d;
      font-size: 12px;
      margin-bottom: 2px;
    }

    .relatorio-tabela th {
      white-space: nowrap;
    }

    .relatorio-assinaturas {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 56px;
      margin-top: 64px;
    }

    .relatorio-assinatura {
      border-top: 1px solid #212529;
      padding-top: 8px;
      text-align: center;
      font-size: 13px;
    }

    @media (max-width: 992px) {
      .relatorio-meta {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 576px) {
      .relatorio-meta,
      .relatorio-assinaturas {
        grid-template-columns: 1fr;
      }
    }

    @media print {
      @page {
        size: A4;
        margin: 1.4cm;
      }

      html,
      body {
        width: 210mm;
        background: #fff !important;
        color: #000 !important;
      }

      .sidebar,
      .no-print,
      .filtros,
      .btn {
        display: none !important;
      }

      .main-content {
        margin: 0 !important;
        padding: 0 !important;
        width: 100% !important;
      }

      .container-fluid {
        padding: 0 !important;
      }

      .relatorio-documento {
        border: 0 !important;
        box-shadow: none !important;
        padding: 0 !important;
      }

      .relatorio-cabecalho {
        padding-bottom: 14px;
      }

      .relatorio-meta {
        grid-template-columns: repeat(4, 1fr);
      }

      .relatorio-meta-item {
        background: #fff !important;
        border-color: #adb5bd;
      }

      .table {
        font-size: 11px;
      }

      .table th,
      .table td {
        border-color: #adb5bd !important;
        padding: 6px 8px !important;
      }

      thead {
        display: table-header-group;
      }

      tr {
        break-inside: avoid;
      }

      .relatorio-assinaturas {
        break-inside: avoid;
      }
    }
  </style>
</head>

<body class="bg-light">

  <aside class="sidebar text-bg-dark" id="sidebar">
    <div class="d-flex flex-column p-3 h-100">

      <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0 sidebar-title">Painel</h4>

        <button id="toggleSidebar" class="btn btn-dark border-0">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>

      <%- include('partials/sidebar') %>

      <hr>

      <a href="/logout" class="btn btn-outline-light mt-auto logout-btn">
        <i class="bi bi-box-arrow-right me-2"></i><span>Sair</span>
      </a>
    </div>
  </aside>

  <main class="main-content p-4">
    <div class="container-fluid">
      <%
        const alunoSelecionado = alunos.find(item => String(item.id) === String(filtros.aluno));
        const formatarDataFiltro = (valor) => {
          if (!valor) return 'Todos';
          const partes = String(valor).split('-');
          return partes.length === 3 ? `${partes[2]}/${partes[1]}/${partes[0]}` : valor;
        };
      %>

      <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-4 no-print">
        <div>
          <h1 class="h3 mb-1">Relatório de Advertências</h1>
          <p class="text-muted mb-0">Data de emissão: <%= dataEmissao %></p>
        </div>

        <div class="d-flex gap-2 align-self-lg-start">
          <a href="/advertencias" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Voltar
          </a>

          <button type="button" onclick="window.print()" class="btn btn-danger">
            <i class="bi bi-printer me-2"></i>Imprimir / Salvar PDF
          </button>
        </div>
      </div>

      <div class="card border-0 shadow-sm rounded-4 mb-4 filtros">
        <div class="card-body">
          <form action="/advertencias/relatorio" method="GET" class="row g-3 align-items-end">
            <div class="col-12 col-lg-4">
              <label for="aluno" class="form-label">Aluno</label>
              <select id="aluno" name="aluno" class="form-select">
                <option value="">Todos</option>
                <% alunos.forEach(item => { %>
                  <option value="<%= item.id %>" <%= String(filtros.aluno) === String(item.id) ? 'selected' : '' %>>
                    <%= item.nome %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="col-12 col-md-6 col-lg-3">
              <label for="dataInicio" class="form-label">Data inicial</label>
              <input
                type="date"
                id="dataInicio"
                name="dataInicio"
                class="form-control"
                value="<%= filtros.dataInicio %>"
              >
            </div>

            <div class="col-12 col-md-6 col-lg-3">
              <label for="dataFim" class="form-label">Data final</label>
              <input
                type="date"
                id="dataFim"
                name="dataFim"
                class="form-control"
                value="<%= filtros.dataFim %>"
              >
            </div>

            <div class="col-12 col-lg-2">
              <button type="submit" class="btn btn-success w-100">
                Filtrar
              </button>
            </div>
          </form>
        </div>
      </div>

      <section class="relatorio-documento rounded-4 p-4 p-lg-5">
        <header class="relatorio-cabecalho d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
          <div class="d-flex align-items-center gap-3">
            <div class="relatorio-marca">
              <img src="/css/img/logo.png" alt="Logo da escola">
            </div>

            <div>
              <p class="text-uppercase text-muted small fw-semibold mb-1">Projeto.Lebon.Regis_Civico.Militar</p>
              <h2 class="h4 mb-1">Relatório de Advertências</h2>
              <p class="text-muted mb-0">Documento gerado em <%= dataEmissao %></p>
            </div>
          </div>

          <div class="text-md-end">
            <p class="text-muted small mb-1">Emitido por</p>
            <p class="fw-semibold mb-0"><%= usuario.nome || usuario.login || 'Usuário do sistema' %></p>
          </div>
        </header>

        <div class="relatorio-meta mb-4">
          <div class="relatorio-meta-item">
            <span>Aluno</span>
            <strong><%= alunoSelecionado ? alunoSelecionado.nome : 'Todos' %></strong>
          </div>

          <div class="relatorio-meta-item">
            <span>Data inicial</span>
            <strong><%= formatarDataFiltro(filtros.dataInicio) %></strong>
          </div>

          <div class="relatorio-meta-item">
            <span>Data final</span>
            <strong><%= formatarDataFiltro(filtros.dataFim) %></strong>
          </div>

          <div class="relatorio-meta-item">
            <span>Total</span>
            <strong><%= advertencias.length %> advertência(s)</strong>
          </div>
        </div>

        <div>
          <div class="table-responsive">
            <table class="table table-bordered align-middle relatorio-tabela">
              <thead class="table-light">
                <tr>
                  <th>Data</th>
                  <th>Nome do aluno</th>
                  <th>Turma</th>
                  <th>Motivo/descrição</th>
                  <th>Responsável</th>
                </tr>
              </thead>

              <tbody>
                <% if (advertencias.length === 0) { %>
                  <tr>
                    <td colspan="5" class="text-center text-muted py-4">
                      Nenhuma advertência encontrada.
                    </td>
                  </tr>
                <% } %>

                <% advertencias.forEach(advertencia => { %>
                  <tr>
                    <td><%= advertencia.data || '-' %></td>
                    <td><%= advertencia.nomeAluno %></td>
                    <td><%= advertencia.turma || '-' %></td>
                    <td><%= advertencia.motivo || '-' %></td>
                    <td><%= advertencia.responsavel || '-' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <p class="fw-semibold mb-0 mt-3">
            Total de advertências: <%= advertencias.length %>
          </p>

          <div class="relatorio-assinaturas">
            <div class="relatorio-assinatura">
              Responsável pela emissão
            </div>

            <div class="relatorio-assinatura">
              Coordenação / Direção
            </div>
          </div>
        </div>
      </section>

    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/dashboard.js"></script>
</body>
</html>
